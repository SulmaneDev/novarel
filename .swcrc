{
	"$schema": "https://swc.rs/schema.json",
	"jsc": {
		"parser": {
			"syntax": "typescript",
			"decorators": true,
			"decoratorsBeforeExport": true
		},
		"transform": {
			"decoratorMetadata": true,
			"legacyDecorator": true
		},
		"target": "es2020"
	},
	"module": {
		"type": "es6",
		"strict": true,
		"strictMode": true,
		"lazy": false
	},
	"minify": false
}
