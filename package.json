{
  "name": "novarel",
  "version": "1.0.0",
  "description": "Novarel is an opinionated Node.js framework with built-in features like robust routing, declarative MVC, a powerful DB API, and versatile rendering (SSR, CSR, ISR, SSG). Designed for scalability, it includes event-driven architecture, factories, seeders, and more",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "watch": "swc src --out-dir dist --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "bin": {
    "novarel": "./dist/src/cli/bin.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SulmaneDev/novarel.git"
  },
  "keywords": [
    "nodejs",
    "framework",
    "mvc",
    "routing",
    "ssr",
    "csr",
    "isr",
    "ssg",
    "orm",
    "database",
    "api",
    "event-driven",
    "scalable",
    "declarative",
    "backend",
    "fullstack",
    "factories",
    "seeders",
    "models",
    "batteries-included"
  ],
  "author": "Sulman Khan <whomaderules@gmail.com>",
