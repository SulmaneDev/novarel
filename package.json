{
    "name": "novarel",
    "version": "1.0.0",
    "description": "A modern, expressive Node.js framework inspired by Laravel",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/SulmaneDev/novarel.git"
    },
    "bugs": {
        "url": "https://github.com/SulmaneDev/novarel/issues"
    },
    "homepage": "https://github.com/SulmaneDev/novarel#readme",
    "keywords": [
        "framework",
        "laravel",
        "expressive",
        "backend",
        "http",
        "api",
        "router",
        "middleware",
        "typescript"
    ],
    "scripts": {
        "lint": "npx eslint src/** --ext .ts,.js,.jsx,.tsx",
        "format": "npx prettier --write src",
        "prepare": "npx husky install"
    },
    "author": "Muhammad Sulman <whomaderules@gmail.com>",
    "engines": {
        "node": ">=20.11.1"
    },
    "license": "MIT",
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^9.29.0",
        "eslint": "^9.29.0",
        "globals": "^16.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.1.2",
        "prettier": "^3.5.3",
        "typescript-eslint": "^8.34.1"
    },
    "lint-staged": {
        "*.{js,ts,json,md}": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}
