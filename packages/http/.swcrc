{
  "jsc": {
    "parser": {
      "syntax": "typescript",
      "tsx": false,
      "decorators": true
    },
    "transform": {
      "decoratorMetadata": true
    },
    "target": "es2020",
    "loose": false
  },
  "module": {
    "type": "nodenext",
    "strict": true
  },
  "sourceMaps": true,
  "minify": false
}